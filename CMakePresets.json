{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 24,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build-make/${presetName}",
            "cacheVariables": {
                "CMAKE_CXX_STANDARD": "20",
                "CMAKE_CXX_STANDARD_REQUIRED": "ON",
                "CMAKE_CXX_EXTENSIONS": "OFF"
            }
        },
        {
            "name": "core-debug",
            "inherits": "base",
            "displayName": "Core Debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "SKYGATE_BUILD_UI": "OFF"
            }
        },
        {
            "name": "ui-debug",
            "inherits": "base",
            "displayName": "UI Debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "SKYGATE_BUILD_UI": "ON"
            }
        },
        {
            "name": "core-coverage",
            "inherits": "base",
            "displayName": "Core Coverage",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "SKYGATE_BUILD_UI": "OFF",
                "SKYGATE_BUILD_TESTS": "ON",
                "SKYGATE_ENABLE_COVERAGE": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "core-debug",
            "configurePreset": "core-debug"
        },
        {
            "name": "ui-debug",
            "configurePreset": "ui-debug"
        },
        {
            "name": "ui-run",
            "configurePreset": "ui-debug",
            "targets": [
                "run-skygate-ui"
            ]
        },
        {
            "name": "core-coverage",
            "configurePreset": "core-coverage"
        },
        {
            "name": "core-coverage-text",
            "configurePreset": "core-coverage",
            "targets": [
                "skygate-coverage-text"
            ]
        },
        {
            "name": "core-coverage-html",
            "configurePreset": "core-coverage",
            "targets": [
                "skygate-coverage-html"
            ]
        }
    ]
}
